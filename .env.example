# Copy this to .env and fill in your values
# NEVER commit .env -- it is in .gitignore

# Kalshi API (get from kalshi.com/settings/api)
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi-private-key.pem

# Alpaca paper trading (optional -- for live paper trading)
ALPACA_API_KEY=your-alpaca-key-here
ALPACA_SECRET_KEY=your-alpaca-secret-here

# Data paths (defaults work for most setups)
PREDICTIONS_FILE=./data/predictions.json
CONFIG_FILE=./data/config.json
